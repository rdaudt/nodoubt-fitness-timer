# Neon Data API + Auth configuration
NEXT_PUBLIC_NEON_DATA_API_URL=https://your-project-ref-data-api.aws.neon.tech/rest/v1
NEXT_PUBLIC_NEON_AUTH_URL=https://your-project-ref.neonauth.us-east-1.aws.neon.tech
NEON_AUTH_BASE_URL=https://your-project-ref.neonauth.us-east-1.aws.neon.tech
NEON_AUTH_COOKIE_SECRET=replace-with-a-32-char-min-secret
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
DATABASE_POOLER_URL=postgresql://user:password@pooler-host/neondb?sslmode=require

# Optional local auth test harness for Playwright.
AUTH_TEST_MODE=0
